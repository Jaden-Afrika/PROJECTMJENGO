rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /progress_photos/{projectId}/{fileName} {
      allow read: if request.auth != null
        && firestore.exists(/databases/(default)/documents/mjengo_projects/$(projectId))
        && firestore.get(/databases/(default)/documents/mjengo_projects/$(projectId)).data.userId == request.auth.uid;

      allow write: if request.auth != null
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && firestore.exists(/databases/(default)/documents/mjengo_projects/$(projectId))
        && firestore.get(/databases/(default)/documents/mjengo_projects/$(projectId)).data.userId == request.auth.uid;
    }
  }
}
